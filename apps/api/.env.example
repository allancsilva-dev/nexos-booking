# ═══════════════════════════════════════════════════
# Runtime (least-privilege) — usado pela API em runtime
# ═══════════════════════════════════════════════════
# Role SEM BYPASSRLS e SEM SUPERUSER para a pool de conexao da API.
# Em producao, APP_RUNTIME_USER (ou DATABASE_RUNTIME_URL) e OBRIGATORIO.
APP_RUNTIME_USER=app_runtime
APP_RUNTIME_PASSWORD=<APP_RUNTIME_PASSWORD>

# Alternativa: connection string completa para runtime.
# Se definida, APP_RUNTIME_USER/APP_RUNTIME_PASSWORD sao ignorados.
# DATABASE_RUNTIME_URL=postgres://app_runtime:<password>@localhost:5432/nexos_booking

# ═══════════════════════════════════════════════════
# Migrations / Owner — usado para DDL e tooling
# ═══════════════════════════════════════════════════
# Role owner do schema. NUNCA usada pela pool runtime em producao.
# Em dev local, serve como fallback se APP_RUNTIME_USER nao estiver definido.
POSTGRES_DB=<POSTGRES_DB>
POSTGRES_HOST=<POSTGRES_HOST>
POSTGRES_PORT=<POSTGRES_PORT>
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_CA_CERT=<POSTGRES_CA_CERT>
JWT_SECRET=<JWT_SECRET_MIN_32_CHARS>
JWT_ISSUER=<JWT_ISSUER>
JWT_AUDIENCE=<JWT_AUDIENCE>
ACCESS_TOKEN_TTL_SECONDS=900
TRUST_PROXY_HOPS=0
WEB_PORT=<WEB_PORT>
API_PORT=<API_PORT>
RESEND_API_KEY=<RESEND_API_KEY>
RESEND_FROM=<RESEND_FROM_EMAIL>
