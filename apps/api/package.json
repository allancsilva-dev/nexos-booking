{
  "name": "@nexos/api",
  "private": true,
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "dev": "pnpm exec tsx watch src/main.ts",
    "lint": "pnpm exec eslint .",
    "migrate:apply": "node ./scripts/apply-migrations.mjs",
    "migrate:fresh": "node ./scripts/apply-migrations.mjs --fresh --gate-setup",
    "start": "node dist/main.js",
    "test:db": "node ./scripts/test-rls.mjs",
    "test:http": "node ./scripts/test-http.mjs",
    "test:auth": "node ./scripts/test-auth.mjs",
    "test:auth-email": "node ./scripts/test-auth-email.mjs",
    "test:maintenance": "node scripts/test-maintenance.mjs"
  },
  "dependencies": {
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@nexos/shared": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "reflect-metadata": "latest",
    "@nestjs/schedule": "^5",
    "resend": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "latest"
  }
}
