{
  "name": "@nexos/api",
  "private": true,
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "dev": "pnpm exec tsx watch src/main.ts",
    "lint": "pnpm exec eslint .",
    "migrate:apply": "node ./scripts/apply-migrations.mjs",
    "migrate:fresh": "node ./scripts/apply-migrations.mjs --fresh --gate-setup",
    "start": "node dist/main.js",
    "test:db": "node ./scripts/test-rls.mjs"
  },
  "dependencies": {
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@nexos/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.21.0",
    "reflect-metadata": "latest",
    "rxjs": "latest"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "latest"
  }
}
